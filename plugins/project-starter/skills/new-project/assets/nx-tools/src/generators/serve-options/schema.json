{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "BeSpunkyServeOptions",
  "title": "Set house dev-server options",
  "type": "object",
  "properties": {
    "project": {
      "type": "string",
      "description": "Name of the project whose serve target to configure.",
      "$default": { "$source": "argv", "index": 0 },
      "x-prompt": "Which project's serve target?"
    },
    "host": {
      "type": "string",
      "description": "Dev-server bind host.",
      "default": "0.0.0.0"
    },
    "poll": {
      "type": "number",
      "description": "File-watching poll interval in ms (reliable over WSL/Docker mounts).",
      "default": 1000
    }
  },
  "required": ["project"]
}
