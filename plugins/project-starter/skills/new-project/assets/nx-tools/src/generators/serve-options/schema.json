{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "BeSpunkyServeOptions",
  "title": "Set house dev-server options",
  "type": "object",
  "properties": {
    "project": {
      "type": "string",
      "description": "Name of the project whose serve target to configure.",
      "$default": { "$source": "argv", "index": 0 },
      "x-prompt": "Which project's serve target?"
    },
    "host": {
      "type": "string",
      "description": "Dev-server bind host (so the server is reachable from outside the devcontainer).",
      "default": "0.0.0.0"
    }
  },
  "required": ["project"]
}
