{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "target": "es2022",
    "strict": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
